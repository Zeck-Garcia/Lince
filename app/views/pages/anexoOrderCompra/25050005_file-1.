SELECT idEntrega, nomeCompletoEntrega, NumeroEncomendaNovaOutrasEncomendas, numeroEncomendaPrincipalOutrasEncomendas, idEntrega, dataCriacaoEncomendaEntrega, contactoEntrega, emailEntrega, MoradaEntrega, codigoPostalEntrega, localidadeEntrega, conselhoEntrega, distritoEntrega, saltoEstadoPedido, dataEstadoPedido, horaEstadoPedido, observacaoEstadoPedido, motivoEstadoPedido, ativoEstadoPedido, dataEntregaOutrasEncomendas, dataCricacaoOutrasEncomendas, localLevantamentoOutrasEncomendas, turnoOutrasEncomendas, motoristaOutrasEncomendas, observacaoClienteOutrasEncomendas,

CASE
WHEN (SELECT COUNT(*) FROM tbOutrasEncomendas WHERE tbOutrasEncomendas.numeroEncomendaPrincipalOutrasEncomendas = '12058177ewfd') = 1
THEN 0
ELSE (SELECT NumeroEncomendaNovaOutrasEncomendas FROM tbOutrasEncomendas WHERE numeroEncomendaPrincipalOutrasEncomendas = '12058177ewfd')
